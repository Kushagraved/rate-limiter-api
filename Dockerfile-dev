FROM golang:1.21-alpine

RUN apk add --no-cache git gcc musl-dev
RUN go install github.com/go-delve/delve/cmd/dlv@v1.22.1

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

EXPOSE 8080 2346

# dlv debug compiles from source on each start — no pre-built binary needed
ENTRYPOINT ["dlv", "debug", "./cmd/server/", \
  "--headless", "--listen=:2346", \
  "--api-version=2", "--accept-multiclient", \
  "--", "-config-path", "config/dev/config.yaml"]
